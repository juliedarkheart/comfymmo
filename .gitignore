# Godot
.godot/
*.import

# Godot export outputs
exports/
builds/

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.tmp

# Logs and local config
*.log
.env
.env.*

# Premium / non-redistributable LICENSED assets — LOCAL ONLY, NEVER COMMIT.
# Sprout Lands (Cup Nooble) and any other paid/non-redistributable packs live
# here, including originals, normalized derivatives, contact sheets, and the
# local activation manifest. The clean checkout must work without these.
licensed_assets/
art/licensed_local/
# Source/editor art files that may ship inside licensed packs.
*.aseprite

# LimeZu (Modern Farm / Modern UI / Modern Exteriors / Modern Interiors /
# Modern Office / Fungus Cave / RPG-Arsenal "Fantasy Battlers") is being evaluated
# as a possible new visual ecosystem. Like Sprout, the ENTIRE vault — original
# zips + .exe generators, extracted packs, normalized/modified derivatives, contact
# sheets, and local activation manifests — is LOCAL ONLY and NEVER committed.
# (licensed_assets/ above already covers this; these are explicit, defensive entries.)
licensed_assets/limezu/
licensed_assets/**/original/
licensed_assets/**/extracted/
licensed_assets/**/normalized/
licensed_assets/**/modified/
licensed_assets/**/contact_sheets/
licensed_assets/**/manifests/

